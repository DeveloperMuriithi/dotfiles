#!/bin/bash

# general settings
yabai -m config mouse_follows_focus          on
yabai -m config focus_follows_mouse         autofocus
yabai -m config window_gap                  10
yabai -m config top_padding                 20
yabai -m config bottom_padding              20
yabai -m config left_padding                20
yabai -m config right_padding               20

# layout
yabai -m config layout                       bsp
yabai -m config split_ratio                  0.5
yabai -m config window_border                on
yabai -m config window_border_width          2
yabai -m config window_border_color          0xff775759
yabai -m config active_window_border_color   0xffd75f5f

# keybindings
skhd -k "alt - h" : yabai -m window --focus west
skhd -k "alt - l" : yabai -m window --focus east
skhd -k "alt - j" : yabai -m window --focus south
skhd -k "alt - k" : yabai -m window --focus north

